APP_NAME=Camuchita Backend
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_PREFIX=/api
PORT=8000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=bodega_backend
DB_USER=root
DB_PASSWORD=change-me
# Opcional: si prefieres una sola variable, puedes usar DATABASE_URL y omitir las variables DB_*.
# DATABASE_URL=mysql+pymysql://usuario:password@host:3306/nombre_base_datos

SECRET_KEY=replace-with-a-secure-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:3000
ALLOWED_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:5173
BACKEND_URL=http://127.0.0.1:8000
